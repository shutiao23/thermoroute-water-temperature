# Python
__pycache__/
*.py[cod]
*.egg-info/
build/
.pytest_cache/
.ipynb_checkpoints/

# OS / editor / local
.DS_Store
.claude/
.idea/
.vscode/

# Large, regenerable artifacts (reproduced by the scripts)
outputs/predictions/
outputs/models/
outputs/logs/
data/processed/

# Per-station intermediate downloads (the combined panels are committed instead)
data_usgs/n*.csv
data_usgs/site_*.csv

# Route-A acquired predictors are immutable release data, not source files.
data_usgs/confirmatory_predictors/
data_usgs/confirmatory_candidate_sites_v1.csv
data_usgs/confirmatory_candidate_sites_v1.provenance.json
data_usgs/confirmatory_site_registry_v1.csv
data_usgs/confirmatory_site_registry_v1.lock.json

# Versioned raw API bytes are archived with the data release rather than Git.
data_usgs/raw_snapshots/*
!data_usgs/raw_snapshots/README.md
!data_usgs/raw_snapshots/huc-v1/
!data_usgs/raw_snapshots/huc-v1/**

# Stray run checkpoints
*_ckpt/

# Mutable advisory-lock diagnostics sit beside content-addressed run
# directories; scientific run manifests/checkpoints remain trackable.
outputs/runs/**/.*.formal-run.lock

# LaTeX build artifacts
*.aux
*.log
*.bbl
*.blg
*.out
*.synctex.gz

# Zenodo release archive (regenerable via scripts/make_release_archive.sh)
dist/
