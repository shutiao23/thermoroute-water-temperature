  "claim_templates": {
    "NEGATED_LIMITATION_NOT_UNGAUGED": "Route A is history-dependent and uses target-site water-temperature observations through each issue date; it does not establish ungauged prediction.",
    "NEGATED_LIMITATION_NO_NETWORK_ROUTING_PROOF": "Route A does not establish independent river-network separation, physical river-network routing, or hydraulic travel time.",
    "NEGATED_LIMITATION_NOT_OPERATIONAL_REPLAY": "Route A is a one-shot retrospective historical-information evaluation, not an operational replay with archived as-issued predictor vintages or future NWP.",
    "NEGATED_LIMITATION_NO_REGULATORY_ECOLOGICAL_MEANING": "Route A uses daily-mean statistical thresholds and a numerical non-inferiority margin; neither has ecological, biological, or regulatory meaning.",
    "NEGATED_LIMITATION_NO_SAFETY_GUARANTEE": "Route A provides no physical, deployment, regulatory, or distribution-free safety guarantee, and failure to reject is not equivalence.",
    "NEGATED_LIMITATION_NO_CAUSAL_MECHANISM": "Route-A architecture controls and predictor sensitivities are descriptive or exploratory and do not identify causal mechanisms.",
    "NEGATED_LIMITATION_NOT_NATIONALLY_REPRESENTATIVE": "Route A evaluates a fixed availability-enriched 120-site cohort and is not nationally representative of all U.S. rivers or all calendar days.",
    "NEGATED_LIMITATION_NO_CONDITIONAL_COVERAGE_OR_CRPS_CLAIM": "Route A does not establish conditional coverage, and its equal-weight three-quantile pinball summary is not CRPS.",
    "SUPERIORITY_SUPPORTED": "Route A {test_id}: SUPERIORITY_SUPPORTED for {candidate} versus {reference} at horizon {horizon} with margin {margin_c} °C; station-median RMSE effect={effect_c} °C, 95% whole-HUC2 cluster-bootstrap CI=[{ci_low_c}, {ci_high_c}] °C, exact whole-HUC2 sign-flip raw p={p_raw}, Holm p={p_holm}, n={n_stations} stations in {n_clusters} clusters.",
    "NONINFERIORITY_SUPPORTED": "Route A {test_id}: NONINFERIORITY_SUPPORTED for {candidate} versus {reference} at horizon {horizon} only against the preregistered {margin_c} °C numerical ceiling; station-median RMSE effect={effect_c} °C, 95% whole-HUC2 cluster-bootstrap CI=[{ci_low_c}, {ci_high_c}] °C, exact whole-HUC2 sign-flip raw p={p_raw}, Holm p={p_holm}, n={n_stations} stations in {n_clusters} clusters. This does not establish equivalence or parity.",
    "NOT_ESTABLISHED": "Route A {test_id}: NOT_ESTABLISHED for {candidate} versus {reference} at horizon {horizon} with margin {margin_c} °C; station-median RMSE effect={effect_c} °C, 95% whole-HUC2 cluster-bootstrap CI=[{ci_low_c}, {ci_high_c}] °C, exact whole-HUC2 sign-flip raw p={p_raw}, Holm p={p_holm}, n={n_stations} stations in {n_clusters} clusters.",
    "EVIDENCE_CONFLICT_NOT_SUPPORTED": "Route A {test_id}: EVIDENCE_CONFLICT_NOT_SUPPORTED for {candidate} versus {reference} at horizon {horizon} with margin {margin_c} °C because the Holm-adjusted exact sign-flip decision and the preregistered whole-HUC2 cluster-bootstrap confidence-bound rule disagree; station-median RMSE effect={effect_c} °C, 95% CI=[{ci_low_c}, {ci_high_c}] °C, raw p={p_raw}, Holm p={p_holm}, n={n_stations} stations in {n_clusters} clusters.",
    "DESCRIPTIVE_ONLY_INFERENCE_GATE_FAILED": "Route A {test_id}: DESCRIPTIVE_ONLY_INFERENCE_GATE_FAILED for {candidate} versus {reference} at horizon {horizon} with margin {margin_c} °C; in the fixed availability-enriched cohort, station-median RMSE effect={effect_c} °C, n={n_stations} reportable stations in {n_clusters} HUC2 clusters. The whole-HUC2 bootstrap interval [{ci_low_c}, {ci_high_c}] °C, exact sign-flip raw p={p_raw}, and Holm p={p_holm} are assumption-conditional sensitivities only because the frozen inference gate failed; they do not support superiority, non-inferiority, equivalence, parity, or a U.S.-river superpopulation claim.",
    "DESCRIPTIVE_ONLY_OUTCOME_QC_GATE_FAILED": "Route A {test_id}: DESCRIPTIVE_ONLY_OUTCOME_QC_GATE_FAILED for {candidate} versus {reference} at horizon {horizon} with margin {margin_c} °C; the unfiltered station-median RMSE effect={effect_c} °C, n={n_stations} reportable stations in {n_clusters} HUC2 clusters. The whole-HUC2 bootstrap interval [{ci_low_c}, {ci_high_c}] °C, exact sign-flip raw p={p_raw}, and Holm p={p_holm} are reported descriptively because the frozen gross-plausibility and aggregate-sensitivity outcome gate failed. No primary row or site was removed, and these values do not support a directional superiority or non-inferiority claim.",
    "DESCRIPTIVE_ONLY_BOTH_GATES_FAILED": "Route A {test_id}: DESCRIPTIVE_ONLY_BOTH_GATES_FAILED for {candidate} versus {reference} at horizon {horizon} with margin {margin_c} °C; the unfiltered fixed-cohort station-median RMSE effect={effect_c} °C, n={n_stations} reportable stations in {n_clusters} HUC2 clusters. The whole-HUC2 bootstrap interval [{ci_low_c}, {ci_high_c}] °C, exact sign-flip raw p={p_raw}, and Holm p={p_holm} are assumption-conditional descriptive sensitivities because both the frozen inference-assumption gate and the frozen gross-plausibility and aggregate-sensitivity outcome gate failed. No primary row or site was removed, and these values do not support superiority, non-inferiority, equivalence, parity, or a U.S.-river superpopulation claim.",
    "NOT_ESTIMABLE": "Route A {test_id}: NOT_ESTIMABLE under the preregistered reportability rule for {candidate} versus {reference} at horizon {horizon} with margin {margin_c} °C; n={n_stations} stations in {n_clusters} clusters."
  },
